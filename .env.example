PORT=3000
DATA_FILE=./data/enquiries.json
DEFAULT_BUFFER_METERS=10
MAX_ADDRESS_CANDIDATES=5
POLL_INTERVAL_MS=15000
MAX_POLL_FAILURES=5
REQUEST_TIMEOUT_MS=20000
LOG_LEVEL=info
BYDA_ENVIRONMENT=production
# Leave BYDA_BASE_URL blank to use the environment default.
# production -> https://smarterwx.1100.com.au/api
# uat -> https://swx-sentinel-uat.smarterdbyd.com/api
BYDA_BASE_URL=
BYDA_CLIENT_ID=
BYDA_CLIENT_SECRET=
BYDA_REQUEST_TIMEOUT_MS=20000
BYDA_USE_MOCK=true

# Optional Docker Hub publish settings for `npm run publish:poller-docker`.
DOCKER_IMAGE=
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# Optional DigitalOcean Spaces storage for the poller.
SPACES_ENABLED=false
SPACES_ENDPOINT=
SPACES_REGION=syd1
SPACES_BUCKET=
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_KEY_PREFIX=byda-reports
SPACES_SIGNED_URL_EXPIRES_SECONDS=604800
SPACES_DOWNLOAD_TIMEOUT_MS=120000
